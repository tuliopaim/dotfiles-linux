#!/usr/bin/env bash

# ============================================================
# yabai configuration — AeroSpace-equivalent setup
# ============================================================
#
sudo /opt/homebrew/bin/yabai --load-sa

# Layout: BSP (equivalent to AeroSpace 'tiles')
yabai -m config layout bsp
yabai -m config window_placement second_child

# Gaps (matching AeroSpace: inner=10, outer=10)
yabai -m config top_padding      10
yabai -m config bottom_padding   10
yabai -m config left_padding      10
yabai -m config right_padding     10
yabai -m config window_gap        10

# Mouse behavior
# AeroSpace: on-focused-monitor-changed move-mouse monitor-lazy-center
yabai -m config mouse_follows_focus on
# focus_follows_mouse disabled: `autofocus` fired extra focus events while
# spaces were mid-transition, leaving the menubar painted with the old
# frontmost app's menu on top of the new one (the "ghost menubar" bug).
# Use alt-h/j/k/l or click to change focus.
yabai -m config focus_follows_mouse off
yabai -m config mouse_modifier alt
yabai -m config mouse_drop_action swap

# External bar offset — uncomment if using SketchyBar
# yabai -m config external_bar all:30:0

# ============================================================
# Ensure 10 macOS Spaces exist (create only what's missing).
# The previous version created 10 every reload, which is why
# accumulated spaces piled up over time.
# ============================================================
current=$(yabai -m query --spaces | grep -c '"index"')
while [ "$current" -lt 10 ]; do
  yabai -m space --create 2>/dev/null || break
  current=$((current + 1))
done

# ============================================================
# Labels & display distribution
#
# 1. labels.sh restore  → UUID-based restore, then fills in any
#    missing canonical labels (ws1..ws9, slack) onto unlabeled
#    spaces. Replaces the old by-index fallback that assigned the
#    wrong labels after spaces reshuffled between displays.
# 2. labels.sh cleanup  → destroys leftover unlabeled orphan spaces.
# 3. distribute.sh      → moves spaces to their intended displays:
#       primary  (built-in): slack, ws6, ws7, ws9
#       external monitor   : ws1, ws2, ws3, ws4, ws5, ws8
#    No-op on single-display hosts.
# 4. labels.sh save     → snapshot for next launch.
#
# yabai v7 rejects purely-numeric labels (would collide with indexes),
# so spaces use a `ws<N>` prefix. skhdrc bindings target these labels.
# ============================================================
LABELS_SH="${HOME}/.config/yabai/labels.sh"
DISTRIBUTE_SH="${HOME}/.config/yabai/distribute.sh"

[ -x "$LABELS_SH" ]     && "$LABELS_SH" restore
[ -x "$LABELS_SH" ]     && "$LABELS_SH" cleanup
[ -x "$DISTRIBUTE_SH" ] && "$DISTRIBUTE_SH"
[ -x "$LABELS_SH" ]     && "$LABELS_SH" save

# ============================================================
# Window rules — auto-float only (no app-to-space assignments)
# ============================================================
# Shottr — screenshot tool, keep it floating outside the tile
yabai -m rule --add app="^cc\\.ffitch\\.shottr$" manage=off

# Common system dialogs that should float
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^Calculator$" manage=off
yabai -m rule --add app="^Dictionary$" manage=off
yabai -m rule --add app="^QuickTime Player$" manage=off
yabai -m rule --add title="Preferences" manage=off
yabai -m rule --add title="Settings" manage=off

# ============================================================
# Signals — event-driven behavior
# ============================================================
# Re-apply persisted labels only when a display is physically added or
# removed. `display_changed` fires on every focus change between monitors,
# which would clobber manual space moves (e.g. dragging slack to the big
# monitor for a focus session) and trigger menubar redraw glitches.
#
# Distribute runs only on display_added — the intent is "snap to home
# layout when a new monitor joins", not "fight the user's manual moves".
# `ctrl+alt-d` is the manual escape hatch.
#
# `space_created` is fired by `--label`, which the ensure step calls,
# so we save on space_destroyed only — saving on creation would race with
# the labelling pass and snapshot empty labels.
for sig in \
  labels_restore_display_added \
  labels_restore_display_removed \
  labels_restore_display_changed \
  labels_distribute_display_added \
  labels_distribute_display_changed \
  labels_save_space_created \
  labels_save_space_destroyed; do
  yabai -m signal --remove "$sig" 2>/dev/null || true
done

yabai -m signal --add label="labels_restore_display_added"      event=display_added   action="$HOME/.config/yabai/labels.sh restore"
yabai -m signal --add label="labels_restore_display_removed"    event=display_removed action="$HOME/.config/yabai/labels.sh restore"
yabai -m signal --add label="labels_distribute_display_added"   event=display_added   action="$HOME/.config/yabai/distribute.sh"
yabai -m signal --add label="labels_save_space_destroyed"       event=space_destroyed action="$HOME/.config/yabai/labels.sh save"

echo "yabai config loaded: $(date)"
