#!/bin/sh

set -eu

SCRIPT_NAME=${0##*/}
STATE_DIR=${XDG_RUNTIME_DIR:-/tmp}
STATE_FILE="${STATE_DIR%/}/handy-gemini-transcription.state"
BUSY_LOCK_DIR="${STATE_DIR%/}/handy-gemini-transcription.lock"
DB_PATH="${HANDY_DB_PATH:-$HOME/.local/share/com.pais.handy/history.db}"
API_BASE="${HANDY_GEMINI_API_BASE:-https://generativelanguage.googleapis.com/v1beta}"
MODEL_NAME="${HANDY_GEMINI_MODEL:-${GEMINI_MODEL:-gemma-3n-e4b-it}}"
POLL_SECONDS="${HANDY_GEMINI_POLL_SECONDS:-20}"
PROMPT="${HANDY_GEMINI_PROMPT:-You are editing speech-to-text output for a Brazilian software developer writing to coworkers in the United States. If the transcript is in Portuguese, translate it to natural United States English. If it is already in English, keep it in English and fix recognition mistakes, spelling, punctuation, capitalization, and small grammar issues. If it is mixed Portuguese and English, translate the Portuguese parts to natural United States English and keep the whole result in English. Preserve the original meaning, tone, and intent. Do not add new information. Keep code, commands, identifiers, URLs, and product names unchanged. Return only the final text.}"
PRIVATE_ENV_FILE="${HANDY_GEMINI_ENV_FILE:-$HOME/dotfiles/private/private.sh}"

usage() {
  cat <<EOF
Usage:
  $SCRIPT_NAME
  $SCRIPT_NAME --correct-stdin

Environment:
  GEMINI_API_KEY                 Required unless available via $PRIVATE_ENV_FILE
  HANDY_GEMINI_MODEL             Optional, defaults to $MODEL_NAME
  HANDY_DB_PATH                  Optional, defaults to $DB_PATH
  HANDY_GEMINI_API_BASE          Optional, defaults to $API_BASE
  HANDY_GEMINI_POLL_SECONDS      Optional, defaults to $POLL_SECONDS
  HANDY_GEMINI_PROMPT            Optional prompt override
EOF
}

notify() {
  printf '%s\n' "$1" >&2
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "$SCRIPT_NAME" "$1"
  fi
}

require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    notify "Missing required command: $1"
    exit 1
  fi
}

load_private_env() {
  if [ -z "${GEMINI_API_KEY:-}" ] && [ -r "$PRIVATE_ENV_FILE" ]; then
    # shellcheck disable=SC1090
    . "$PRIVATE_ENV_FILE"
  fi
}

require_api_runtime() {
  require_command jq
  require_command curl
  load_private_env

  if [ -z "${GEMINI_API_KEY:-}" ]; then
    notify "GEMINI_API_KEY is not set"
    exit 1
  fi
}

require_toggle_runtime() {
  require_command handy
  require_command sqlite3
  require_command wl-copy
  require_command wtype
  require_api_runtime

  if [ ! -r "$DB_PATH" ]; then
    notify "Handy history database not found at $DB_PATH"
    exit 1
  fi
}

busy() {
  [ -d "$BUSY_LOCK_DIR" ]
}

acquire_busy_lock() {
  mkdir "$BUSY_LOCK_DIR" 2>/dev/null
}

release_busy_lock() {
  rmdir "$BUSY_LOCK_DIR" 2>/dev/null || true
}

latest_entry_id() {
  entry_id=$(sqlite3 -readonly "$DB_PATH" "SELECT COALESCE(MAX(id), 0) FROM transcription_history;" 2>/dev/null || true)
  printf '%s\n' "${entry_id:-0}"
}

wait_for_new_entry_id() {
  baseline_id=$1
  elapsed=0

  while [ "$elapsed" -lt "$POLL_SECONDS" ]; do
    entry_id=$(sqlite3 -readonly "$DB_PATH" "SELECT id FROM transcription_history WHERE id > $baseline_id ORDER BY id DESC LIMIT 1;" 2>/dev/null || true)
    if [ -n "$entry_id" ]; then
      printf '%s\n' "$entry_id"
      return 0
    fi
    sleep 1
    elapsed=$((elapsed + 1))
  done

  return 1
}

transcription_text_for_id() {
  sqlite3 -readonly "$DB_PATH" "SELECT transcription_text FROM transcription_history WHERE id = $1 LIMIT 1;"
}

normalized_model_name() {
  case "$1" in
    models/*)
      printf '%s\n' "${1#models/}"
      ;;
    *)
      printf '%s\n' "$1"
      ;;
  esac
}

correct_text() {
  input_text=$1
  model_path=$(normalized_model_name "$MODEL_NAME")
  response_file=$(mktemp "${TMPDIR:-/tmp}/handy-gemini-response.XXXXXX")
  http_code=""

  cleanup_response_file() {
    rm -f "$response_file"
  }

  trap cleanup_response_file EXIT INT TERM
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "$SCRIPT_NAME" "Gemini is cleaning the transcript..."
  fi

  http_code=$(
    jq -n \
      --arg prompt "$PROMPT\n\nTranscript:\n$input_text" \
      '{
        contents: [
          {
            parts: [
              { text: $prompt }
            ]
          }
        ],
        generationConfig: {
          temperature: 0
        }
      }' |
      curl -sS \
        -H 'Content-Type: application/json' \
        -X POST \
        -d @- \
        -o "$response_file" \
        -w '%{http_code}' \
        "$API_BASE/models/$model_path:generateContent?key=$GEMINI_API_KEY"
  ) || {
    trap - EXIT INT TERM
    cleanup_response_file
    return 1
  }

  response=$(cat "$response_file")

  if [ "$http_code" -lt 200 ] || [ "$http_code" -ge 300 ]; then
    api_error=$(printf '%s' "$response" | jq -r '.error.message // empty' 2>/dev/null || true)
    if [ -n "$api_error" ]; then
      notify "Gemini API error: $api_error"
    else
      notify "Gemini HTTP error: $http_code"
    fi
    trap - EXIT INT TERM
    cleanup_response_file
    return 1
  fi

  corrected=$(
    printf '%s' "$response" |
      jq -r '
        if .candidates[0].content.parts then
          [.candidates[0].content.parts[]?.text // ""] | join("")
        else
          empty
        end
      '
  )

  if [ -n "$corrected" ]; then
    trap - EXIT INT TERM
    cleanup_response_file
    printf '%s' "$corrected"
    return 0
  fi

  api_error=$(printf '%s' "$response" | jq -r '.error.message // empty')
  if [ -n "$api_error" ]; then
    notify "Gemini API error: $api_error"
  fi

  trap - EXIT INT TERM
  cleanup_response_file
  return 1
}

start_mode() {
  if busy; then
    notify "Gemini is still cleaning the previous transcript"
    exit 1
  fi

  umask 077
  latest_entry_id > "$STATE_FILE"

  if ! handy --toggle-transcription; then
    rm -f "$STATE_FILE"
    notify "Failed to start Handy transcription"
    exit 1
  fi
}

stop_mode() {
  baseline_id=$(cat "$STATE_FILE")

  if ! handy --toggle-transcription; then
    notify "Failed to stop Handy transcription"
    exit 1
  fi

  rm -f "$STATE_FILE"

  if ! new_entry_id=$(wait_for_new_entry_id "$baseline_id"); then
    notify "No new Handy transcription was saved"
    exit 1
  fi

  raw_text=$(transcription_text_for_id "$new_entry_id")
  if [ -z "$raw_text" ]; then
    notify "Handy returned an empty transcription"
    exit 1
  fi

  if ! acquire_busy_lock; then
    notify "Gemini is already cleaning another transcript"
    exit 1
  fi

  cleanup_stop_mode() {
    release_busy_lock
  }

  trap cleanup_stop_mode EXIT INT TERM

  if corrected_text=$(correct_text "$raw_text"); then
    :
  else
    corrected_text=$raw_text
    notify "Gemini cleanup failed; keeping Handy transcription"
  fi

  printf '%s' "$corrected_text" | wl-copy --type text/plain
  wtype -M ctrl -k v -m ctrl
  trap - EXIT INT TERM
  cleanup_stop_mode
}

correct_stdin_mode() {
  require_api_runtime
  stdin_text=$(cat)

  if [ -z "$stdin_text" ]; then
    notify "No input received on stdin"
    exit 1
  fi

  correct_text "$stdin_text"
}

main() {
  case "${1:-}" in
    --help|-help|help)
      usage
      ;;
    --correct-stdin)
      correct_stdin_mode
      ;;
    "")
      require_toggle_runtime
      if [ -f "$STATE_FILE" ]; then
        stop_mode
      else
        start_mode
      fi
      ;;
    *)
      usage >&2
      exit 64
      ;;
  esac
}

main "${1:-}"
