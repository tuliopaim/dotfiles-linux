#!/usr/bin/env bash
# fzf-pick a folder under ~/dev and focus (or create) a herdr workspace for it.
# Mirrors the spirit of tmux-worktree --session: one workspace per worktree.

set -euo pipefail

BASE_DIR="${HOME}/dev"

if [[ $# -ge 1 ]]; then
    selected=$(echo "$1" | tr -s '/')
else
    selected=$(find "$BASE_DIR" -mindepth 1 -maxdepth 3 -type d \
        -not -path '*/.bare*' -print \
        | fzf --reverse --prompt 'worktree > ' \
              --border --border-label ' herdr worktrees ' \
              --preview 'ls -la {}' --preview-window 'right:55%')
fi

[[ -z "$selected" ]] && exit 0

# Derive label from path: <category>/<repo>/<branch>
escaped_base_dir=$(printf %s "$BASE_DIR" | sed 's/\//\\\//g')
regex_pattern="^${escaped_base_dir}/([^/]+)(/([^/]+))?(/([^/]+))?$"

if [[ "$selected" =~ $regex_pattern ]]; then
    category="${BASH_REMATCH[1]}"
    repo="${BASH_REMATCH[3]}"
    branch="${BASH_REMATCH[5]}"

    if [[ -z "$repo" ]]; then
        repo="$category"
        branch=""
    fi

    repo=$(echo "$repo" | tr '.:#' '_')
    branch=$(echo "$branch" | tr '.:#' '_')

    if [[ -n "$branch" ]]; then
        label="${repo}-${branch}"
    else
        label="$repo"
    fi
else
    label=$(basename "$selected" | tr '.:#' '_')
fi

existing=$(herdr workspace list 2>/dev/null \
    | jq -r --arg label "$label" \
        '.result.workspaces[]? | select(.label==$label) | .workspace_id' \
    | head -n1)

if [[ -n "$existing" ]]; then
    herdr workspace focus "$existing" >/dev/null
else
    herdr workspace create --cwd "$selected" --label "$label" --focus >/dev/null
fi
