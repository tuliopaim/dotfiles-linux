      },
      "researcher": {
        "model": "opencode-go/deepseek-v4-flash",
        "thinking": "medium"
      },
      "context-builder": {
        "model": "opencode-go/kimi-k2.7-code",
        "thinking": "medium"
      },
      "planner": {
        "model": "openai-codex/gpt-5.6-sol",
        "thinking": "medium"
      },
      "reviewer": {
        "model": "openai-codex/gpt-5.6-sol",
        "thinking": "medium"
      },
      "oracle": {
        "model": "openai-codex/gpt-5.6-sol",
        "thinking": "high"
      }
    }
  },
  "theme": "dark"
}