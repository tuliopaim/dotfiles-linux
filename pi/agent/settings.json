      },
      "planner": {
        "model": "github-copilot/gpt-5.5",
        "thinking": "low"
      },
      "worker": {
        "model": "github-copilot/gpt-5.5",
        "thinking": "low"
      },
      "reviewer": {
        "model": "github-copilot/gpt-5.5",
        "thinking": "medium"
      },
      "oracle": {
        "model": "github-copilot/gpt-5.5",
        "thinking": "high"
