{
    "$schema": "https://opencode.ai/config.json",
    "plugin": [
        "opencode-anthropic-auth"
    ],
    "autoupdate": true,
    "permission": {
        "external_directory": {
            "$HOME/dev": "allow",
            "$HOME/dev/**": "allow"
        }
    },
    "mcp": {
        "chrome-devtools": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "chrome-devtools-mcp@latest"
            ]
        }
    }
}
