#!/usr/bin/env bash
set -euo pipefail

IMAGE="dotfiles-dotnet:latest"
CONTAINER_NAME="dotnet-dev"
BUILD=false

usage() {
    echo "Usage: dotnet-dev [--build] [--name <name>] <project-dir>"
    exit 1
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --build)
            BUILD=true
            shift
            ;;
        --name)
            CONTAINER_NAME="$2"
            shift 2
            ;;
        -*)
            usage
            ;;
        *)
            PROJECT_DIR="$1"
            shift
            ;;
    esac
done

if [[ -z "${PROJECT_DIR:-}" ]]; then
    usage
fi

# Resolve to absolute path
PROJECT_DIR="$(cd "$PROJECT_DIR" && pwd)"

if [[ "$BUILD" == true ]]; then
    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
    "$SCRIPT_DIR/../dotnet/build.sh"
fi

docker run -it --rm \
    --name "$CONTAINER_NAME" \
    -v "$PROJECT_DIR":/workspace \
    -v ~/.ssh:/home/dev/.ssh:ro \
    -w /workspace \
    "$IMAGE"
